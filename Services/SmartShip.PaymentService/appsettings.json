{
  "ConnectionStrings": {
    "Default": "Server=.\\SQLEXPRESS;Database=SmartShipPaymentDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "SmartShip$SuperSecret$Key$2026!@#XYZ",
    "Issuer": "SmartShipGateway",
    "Audience": "SmartShipClients"
  },
  "Razorpay": {
    "KeyId": "rzp_test_XXXXXXXX",
    "KeySecret": "XXXXXXXXXXXXXXXX"
  },
  "Services": {
    "ShipmentService": "http://localhost:5002/"
  },

  "Serilog": {
    "MinimumLevel": {
