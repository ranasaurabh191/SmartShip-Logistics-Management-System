    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:dd-MMM hh:mm tt} IST] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
